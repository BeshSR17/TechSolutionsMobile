{
  "expo": {
    "name": "Tech Solutions",
    "slug": "TechSolutionsMobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/LogoApp.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tuusuario.techsolutions"
    },
    "android": {
      "package": "com.tuusuario.techsolutions",
      
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "La aplicación necesita acceso a tus fotos para que puedas elegir una imagen de perfil.",
          "cameraPermission": "La aplicación necesita acceso a la cámara para tomar fotos de perfil."
        }
      ],
      "@react-native-community/datetimepicker"
      
    ],
    "extra": {
      "eas": {
        "projectId": "a9f4f7bc-d2df-4515-b3a6-177c5dcd6059"
      }
    }
  }
}
